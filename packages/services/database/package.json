{
  "name": "@service/database",
  "exports": {
    ".": "./index.ts",
    "./post": "./prisma/post/generated/client.ts",
    "./user": "./prisma/user/generated/client.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "sync": "tsx scripts/sync.ts",
    "dev": "tsdown --watch",
    "prisma:validate": "lnv prisma:validate",
    "prisma:generate": "lnv prisma:generate && pnpm sync && pnpm build",
    "prisma:migrate:dev": "lnv prisma:migrate:dev",
    "prisma:format": "lnv prisma:format",
    "prisma:studio": "lnv prisma:studio",
    "prisma:db:push": "lnv prisma:db:push",
    "prisma:db:pull": "lnv prisma:db:pull",
    "prisma": "lnv prisma"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:prisma",
    "@prisma/client": "catalog:prisma"
  },
  "devDependencies": {
    "@hairy/lnv": "catalog:cli",
    "prisma": "catalog:prisma",
    "tsdown": "catalog:cli",
    "tsx": "catalog:cli"
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.mjs",
      "./post": "./dist/post.mjs",
      "./user": "./dist/user.mjs",
      "./package.json": "./package.json"
    }
  }
}
